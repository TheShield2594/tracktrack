data/
*.db
*.db-shm
*.db-wal

# Dev / OS artefacts
.DS_Store
*.log
.env
.env.local
.env.*.local

# Git
.git/
.gitignore

# Editor
.vscode/
.idea/
*.swp
*.swo

# Docs (not needed at runtime)
README.md
CHANGELOG.md
